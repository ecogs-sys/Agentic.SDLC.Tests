# Copy this file to .env and fill in the values before running docker compose.
# The .env file is read automatically by docker compose from the same directory.

# PostgreSQL credentials — used by both the db service and the api connection string.
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=contactdb

# ASP.NET Core runtime environment (Development | Staging | Production).
ASPNETCORE_ENVIRONMENT=Production

# Origin that the CORS policy on the API will allow.
# For local use this should match the host:port you access the frontend on.
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Build-time URL the React app uses to reach the API.
VITE_API_BASE_URL=http://localhost:8080
