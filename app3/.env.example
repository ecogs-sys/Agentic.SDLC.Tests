# ============================================================
# Contact Us Application — Environment Variables
# ============================================================
# Copy this file to .env and adjust values before running:
#   cp .env.example .env
#
# All variables below are consumed by docker-compose.yml.
# ============================================================

# ---- PostgreSQL (db service) --------------------------------
# Password for the contact_user database account.
# Change this to a strong secret in any non-local environment.
POSTGRES_PASSWORD=contact_pw

# ---- Backend (backend service) ------------------------------
# ASP.NET Core environment. Use Production to disable Swagger.
ASPNETCORE_ENVIRONMENT=Production

# CORS allow-origin sent to the browser. Must match the URL
# used to open the frontend. Default: http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# ---- Frontend build arg (frontend service) ------------------
# Base URL for API calls, baked into the Vite bundle at build
# time. Leave as /api so the Nginx proxy routes correctly.
VITE_API_BASE_URL=/api
